      "w": 12,
      "h": 10,
      "config": {
        "name": "Error Rate",
        "source": "mylogs",
        "displayType": "stacked_bar",
        "numberFormat": {
          "output": "percent",
          "mantissa": 2,
          "thousandSeparated": true,
          "average": false,
          "decimalBytes": false,
          "factor": 1
        },
        "granularity": "auto",
        "fillNulls": 0,
        "compareToPreviousPeriod": false,
        "alignDateRangeToGranularity": true,
        "select": [
          {
            "aggFn": "none",
            "aggCondition": "",
            "aggConditionLanguage": "lucene",
            "valueExpression": "countIf(level='Error') / count()",
            "alias": "Error rate"
          }
        ],
        "where": "",
        "whereLanguage": "lucene"
      }
    },
    {
